# Copy to .env and fill in. .env is git-ignored.
# All secrets live in ~/.burla/<email>/.env — this top-level .env is only
# used by the onboarder to know *which* account to provision.

BURLA_EMAIL=you@example.com
# Optional: "google" (default) or "microsoft"
BURLA_AUTH_PROVIDER=google
# Optional: override the cluster URL (usually filled in automatically
# after `burla login` by reading ~/Library/Application Support/burla/burla_credentials.json).
BURLA_URL=
